   "source": [
    "import torch\n",
    "\n",
    "# Define variables\n",
    "x = torch.tensor(2.0, requires_grad=True)\n",
    "y = torch.tensor(3.0, requires_grad=True)\n",
    "\n",
    "# Function\n",
    "f = x**2 + y**2 + x*y\n",
    "\n",
    "# Backward\n",
    "f.backward()\n",
    "\n",
    "print(\"df/dx:\", x.grad.item())\n",
    "print(\"df/dy:\", y.grad.item())"
   ]
  }
 ],
