   "source": [
    "import torch\n",
    "\n",
    "# Define x with gradient tracking\n",
    "x = torch.tensor(2.0, requires_grad=True)\n",
    "\n",
    "# Compute function\n",
    "f = x**2 + 3*x + 5\n",
    "\n",
    "# Backward pass\n",
    "f.backward()\n",
    "\n",
    "print(\"Function value:\", f.item())\n",
    "print(\"Gradient (df/dx):\", x.grad.item())"
   ]
  }
 ],
